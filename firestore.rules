rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isAuthenticated() && isValidId(userId) && userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidId(userId) && userId == request.auth.uid &&
                    incoming().keys().hasAll(['uid', 'name', 'createdAt']) &&
                    incoming().keys().size() == 3 &&
                    incoming().uid == request.auth.uid &&
                    incoming().name is string && incoming().name.size() <= 100 &&
                    incoming().createdAt == request.time;
      allow update, delete: if false;
    }

    // --- Challenge ---
    function isValidChallenge(data) {
      return data.keys().hasAll(['code', 'name', 'ownerId', 'durationDays', 'createdAt', 'endsAt']) &&
             data.keys().size() == 6 &&
             data.code is string && data.code.size() == 6 && data.code.matches('^[A-Z0-9]+$') &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.durationDays is number && data.durationDays > 0 && data.durationDays <= 180 &&
             data.createdAt == request.time &&
             data.endsAt is timestamp;
    }

    match /challenges/{challengeId} {
      allow get: if isAuthenticated() && isValidId(challengeId);

      allow create: if isAuthenticated() && 
                    isValidId(challengeId) && 
                    isValidChallenge(incoming()) && 
                    challengeId == incoming().code;
      
      allow update: if false;
      allow delete: if false;

      match /members/{userId} {
        function isValidMember(data) {
          return data.keys().hasAll(['userId', 'userName', 'xp', 'joinedAt']) &&
                 data.keys().size() == 4 &&
                 data.userId is string && data.userId == request.auth.uid &&
                 data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100 &&
                 data.xp is number && data.xp >= 0 &&
                 data.joinedAt == request.time;
        }

        // Anyone authenticated can read members of a challenge if they know the challengeId
        // This allows rendering the leaderboard.
        allow get: if isAuthenticated() && isValidId(challengeId) && isValidId(userId);
        allow list: if isAuthenticated() && isValidId(challengeId);

        allow create: if isAuthenticated() && 
                      isValidId(challengeId) && 
                      isValidId(userId) && 
                      userId == request.auth.uid &&
                      isValidMember(incoming());

        allow update: if isAuthenticated() && 
                      isValidId(challengeId) && 
                      isValidId(userId) && 
                      userId == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'userName']) &&
                      incoming().xp is number && incoming().xp >= existing().xp &&
                      (incoming().userName is string ? (incoming().userName.size() > 0 && incoming().userName.size() <= 100) : true) &&
                      incoming().userId == existing().userId &&
                      incoming().joinedAt == existing().joinedAt;
        
        allow delete: if false;
      }
    }
  }
}
